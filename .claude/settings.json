{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf *)",
      "Bash(git push --tags:*)",
      "Bash(git push --follow-tags:*)",
      "Bash(git tag -a:*)",
      "Bash(git tag -d:*)",
      "Bash(git tag -f:*)",
      "Bash(git tag -s:*)",
      "Bash(gh release create:*)",
      "Bash(gh release delete:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/git/block-tags.sh\""
          }
        ]
      }
    ]
  }
}
