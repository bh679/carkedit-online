{
  "name": "carkedit-online",
  "version": "1.09.0021",
  "description": "CarkedIt Online — turn-based card game web app (vanilla HTML/CSS/JS)",
  "requiredApiVersion": "0.03.0008",
  "main": "index.html",
  "engines": {
    "node": ">=22.22.2"
  },
  "scripts": {
    "prepare": "node scripts/install-githooks.js",
    "prestart": "bash scripts/setup-worktree-assets.sh",
    "start": "npx http-server . -p ${PORT:-4600} -c-1",
    "stamp-api-version": "node scripts/stamp-required-api-version.js",
    "test": "playwright test",
    "test:unit": "node --test 'js/**/*.test.js' 'scripts/**/*.test.js'",
    "test:report": "playwright show-report"
  },
  "keywords": [
    "card-game",
    "multiplayer",
    "vanilla-js"
  ],
  "author": "bh679",
  "license": "BUSL-1.1",
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
